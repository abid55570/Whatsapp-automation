# ========================================
# Application
# ========================================
APP_ENV=development
APP_NAME="WhatsApp Business Automation"
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ========================================
# Database (PostgreSQL)
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=whatsapp_saas
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/whatsapp_saas
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/whatsapp_saas

# ========================================
# Redis (Queue + Cache)
# ========================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ========================================
# Security  — REQUIRED in production
# ========================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production-use-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Fernet key for encrypting WA access tokens at rest. REQUIRED in production.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ========================================
# Rate limiting (slowapi)
# ========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_PUBLIC=30/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_WRITE=60/minute
RATE_LIMIT_WEBHOOK=2000/minute

# ========================================
# WhatsApp Cloud API (Meta) — per-business credentials
# ========================================
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=change-this-to-random-string
META_GRAPH_API_VERSION=v21.0
META_EMBEDDED_SIGNUP_CONFIG_ID=

# ========================================
# Platform's OWN WhatsApp Business number
# Used for: signup OTP via deep-link verification, system notifications
# ========================================
PLATFORM_WHATSAPP_PHONE_NUMBER=+919999999999
PLATFORM_WHATSAPP_PHONE_NUMBER_ID=
PLATFORM_WHATSAPP_ACCESS_TOKEN=

# ========================================
# Verification
# ========================================
VERIFICATION_CODE_TTL_MINUTES=10

# ========================================
# Razorpay (Payments)  — REQUIRED for paid plans
# ========================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Plan IDs (create on Razorpay dashboard once)
RAZORPAY_PLAN_ID_STARTER=
RAZORPAY_PLAN_ID_GROWTH=
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_AI_ADDON=
RAZORPAY_PLAN_ID_TAX_ADDON=

# ========================================
# Plan pricing (paise) — defaults match the ₹399/999/1999 spec
# ========================================
PLAN_STARTER_PRICE_PAISE=39900
PLAN_GROWTH_PRICE_PAISE=99900
PLAN_PRO_PRICE_PAISE=199900
PLAN_AI_ADDON_PRICE_PAISE=69900
PLAN_TAX_ADDON_PRICE_PAISE=29900

# ========================================
# Cloudflare R2 (invoice PDF storage)  — REQUIRED for Tax Pack
# ========================================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=whatsapp-auto-invoices
R2_PUBLIC_BASE=
INVOICE_SIGNED_URL_TTL_DAYS=7

# ========================================
# e-invoice / IRP  — OPTIONAL, only for businesses with turnover > ₹5 cr
# ========================================
EINVOICE_USERNAME=
EINVOICE_PASSWORD=
EINVOICE_CLIENT_ID=
EINVOICE_CLIENT_SECRET=
EINVOICE_GSTIN=
EINVOICE_BASE=https://einv-apisandbox.nic.in

# ========================================
# Google Sheets API (Service Account)
# ========================================
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials/google-service-account.json
# Client sheet share email:sheets-sync@whatsapp-auto-sheets.iam.gserviceaccount.com

# ========================================
# SMS / OTP (MSG91 or Fast2SMS for India)
# ========================================
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# ========================================
# AI (Optional — AI Add-on)
# ========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5

# ========================================
# Logging & Monitoring
# ========================================
LOG_LEVEL=INFO
SENTRY_DSN=https://3cde05e215fdd566134aa71e2c05d0bd@o4511467091722240.ingest.us.sentry.io/4511467230658560

# ========================================
# Frontend (Next.js)
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="WhatsApp Business Automation"
NEXT_PUBLIC_RAZORPAY_KEY_ID=
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
